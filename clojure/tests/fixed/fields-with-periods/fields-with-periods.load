LOAD FIXED
     FROM inline
          (
           "CHARS.LETTERS" from 0 for 3,
           "CHARS.NUMBERS" from 3 for 3
          )
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.fixed_periods
          (
           "CHARS.LETTERS",
           "CHARS.NUMBERS"
          )

     WITH truncate

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.fixed_periods; $$,
       $$ CREATE TABLE public.fixed_periods (
            "CHARS.LETTERS" char(3),
            "CHARS.NUMBERS" char(3)
          ); $$;

abc123
def456
ghi789
