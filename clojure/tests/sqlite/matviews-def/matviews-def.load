-- #699 regression test: MATERIALIZE VIEWS with an inline SQL definition.
-- The view renames column 'tx' to 'transcript', which is the exact use-case
-- from the original feature request (#699). The SQL is executed against the
-- source SQLite connection and the result is written to PostgreSQL via COPY.
-- pgloader now infers the target table schema from the query result metadata.
LOAD DATABASE
     FROM sqlite:///work/matviews-def/source.sqlite
     INTO postgresql://pgloader:pgloader@postgres:5432/target

     WITH include drop, create tables, reset sequences

     MATERIALIZE VIEWS order_summary
       AS $$ SELECT id, tx AS transcript, amount FROM orders $$;
