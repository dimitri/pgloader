LOAD DBF
     FROM dbf:///work/reg2013/reg2013.dbf
          WITH ENCODING cp850
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE dbf.reg2013

     WITH truncate, create table, disable triggers

     CAST column reg2013.region to integer,
          column reg2013.tncc   to smallint

     BEFORE LOAD DO
       $$ CREATE SCHEMA IF NOT EXISTS dbf; $$;
