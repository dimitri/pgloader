LOAD CSV FROM '/work/guess-csv/track.csv'
             (trackid, track, album, media, genre, composer,
              milliseconds, bytes, unitprice)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE csv.guess_csv

     WITH truncate

     BEFORE LOAD DO
       $$ CREATE SCHEMA IF NOT EXISTS csv; $$,
       $$ DROP TABLE IF EXISTS csv.guess_csv; $$,
       $$ CREATE TABLE csv.guess_csv (
            trackid      bigserial primary key,
            track        text,
            album        text,
            media        text,
            genre        text,
            composer     text,
            milliseconds bigint,
            bytes        bigint,
            unitprice    numeric
          ); $$;
