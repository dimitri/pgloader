LOAD CSV FROM '/work/not-enclosed/not-enclosed.csv'
             ("NOM", "PRENOM")
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_not_enclosed

     WITH truncate,
          fields not enclosed,
          fields terminated by '|'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_not_enclosed; $$,
       $$ CREATE TABLE public.csv_not_enclosed (
            "NOM"    character(20),
            "PRENOM" character(20)
          ); $$;
