LOAD CSV FROM '/work/column-subset/column-subset.csv'
             (a, b, c, d, e)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_column_subset (a, b, c, e)

     WITH drop indexes,
          fields terminated by '%'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_column_subset; $$,
       $$ CREATE TABLE public.csv_column_subset (
            a integer unique,
            b text,
            c text,
            e text
          ); $$,
       $$ CREATE INDEX ON public.csv_column_subset (b); $$;
