LOAD CSV FROM '/work/lines-terminated/lines-terminated.csv'
             (id, name, value)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_lines_terminated

     WITH truncate,
          skip header = 1,
          fields terminated by ',',
          lines terminated by '|'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_lines_terminated; $$,
       $$ CREATE TABLE public.csv_lines_terminated (
            id    integer,
            name  text,
            value text
          ); $$;
