LOAD CSV FROM '/work/trailing/skip2header.csv'
             (a, c, b, trailing)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_trailing (a, b, c)

     WITH truncate,
          skip header = 2,
          fields terminated by '|'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_trailing; $$,
       $$ CREATE TABLE public.csv_trailing (a integer, b date, c text); $$;
