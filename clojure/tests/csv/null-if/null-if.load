LOAD CSV FROM '/work/null-if/null-if.csv'
             (id, number, data)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_null_if

     WITH truncate,
          null if '\N',
          fields terminated by ',',
          fields enclosed by '"',
          fields escaped by backslash-quote

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_null_if; $$,
       $$ CREATE TABLE public.csv_null_if (
            id     integer,
            number integer,
            data   text
          ); $$;
