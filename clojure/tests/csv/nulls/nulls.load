LOAD CSV FROM '/work/nulls/nulls.csv'
             (f1, f2 [null if ""], f3)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_nulls

     WITH truncate,
          fields optionally enclosed by '"',
          fields terminated by ','

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_nulls; $$,
       $$ CREATE TABLE public.csv_nulls (f1 text, f2 text, f3 text); $$;
