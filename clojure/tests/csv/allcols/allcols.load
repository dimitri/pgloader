LOAD CSV FROM '/work/allcols/allcols.csv'
             (a, b, c)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_allcols

     WITH truncate,
          fields optionally enclosed by '"',
          fields terminated by ':'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_allcols; $$,
       $$ CREATE TABLE public.csv_allcols (
            a integer primary key,
            b date,
            c text
          ); $$;
