LOAD CSV FROM '/work/column-order/column-order.csv'
             (c, b)
     INTO postgresql://pgloader:pgloader@postgres:5432/target
     TARGET TABLE public.csv_column_order (b, c)

     WITH truncate,
          fields terminated by ';'

     BEFORE LOAD DO
       $$ DROP TABLE IF EXISTS public.csv_column_order; $$,
       $$ CREATE TABLE public.csv_column_order (
            a serial primary key,
            b date,
            c text
          ); $$;
